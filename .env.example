# ═══════════════════════════════════════════════════════
# easyStudy — 环境变量模板
# 复制为 .env 后填写实际值。.env 不提交到 Git。
#
# 方案B (混合模式):
#   应用进程通过 localhost 连接中间件
#   DB_HOST=localhost  REDIS_HOST=localhost  MINIO_ENDPOINT=localhost:9000
# ═══════════════════════════════════════════════════════

# ── 数据库 (PostgreSQL) ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=easystudy
DB_USER=easystudy
DB_PASSWORD=change_me_in_production

# ── 缓存 (Redis) ──
REDIS_HOST=localhost
REDIS_PORT=6379

# ── 文件存储 (MinIO) ──
MINIO_ENDPOINT=localhost:9000
MINIO_USER=easystudy_admin
MINIO_PASSWORD=change_me_in_production

# ── JWT ──
# 生成方式: openssl rand -hex 32  或在线生成 ≥256 位随机字符串
JWT_SECRET=generate_a_random_256bit_string_here

# ── DeepSeek API ──
# 注意: base_url 末尾不要加 /v1，SDK 会自动追加
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── 讯飞星火 (TTS 语音合成) ──
XUNFEI_APP_ID=your_xunfei_app_id
XUNFEI_API_KEY=your_xunfei_api_key
XUNFEI_API_SECRET=your_xunfei_api_secret

# ── 前端 ──
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── 邮件 (SMTP) ──
# 以 QQ 邮箱为例: 设置 → 账户 → POP3/SMTP 服务 → 开启 → 获取授权码
MAIL_HOST=smtp.qq.com
MAIL_PORT=587
MAIL_USERNAME=your_admin_email@qq.com
MAIL_PASSWORD=your_smtp_authorization_code
MAIL_FROM=your_admin_email@qq.com

# ── Spring Boot ──
SPRING_PROFILES_ACTIVE=dev
